            <Position>
              <LatitudeDegrees>52.149078</LatitudeDegrees>
              <LongitudeDegrees>4.494925</LongitudeDegrees>
            </Position>
            <AltitudeMeters>4.0</AltitudeMeters>
            <DistanceMeters>50.0</DistanceMeters>
            <HeartRateBpm><Value>145</Value></HeartRateBpm>
            <Cadence>84</Cadence>
            <Extensions>
              <ns3:TPX>
                <ns3:Speed>3.6</ns3:Speed>
                <ns3:Watts>260</ns3:Watts>
              </ns3:TPX>
            </Extensions>
          </Trackpoint>
